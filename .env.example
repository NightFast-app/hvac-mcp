# HVAC MCP environment variables
# Copy to .env for local dev. Never commit the real .env.

# Premium tier license key. Leave blank for free-tier-only operation.
# Dev-mode accepts "DEV-LOCAL-KEY-DO-NOT-SHIP" without hitting Stripe.
HVAC_MCP_LICENSE_KEY=

# Stripe secret key for production license validation (phase 3+).
# sk_test_... for test mode, sk_live_... for production.
STRIPE_SECRET=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# HTTP port when running with --http (default 8000)
PORT=8000
