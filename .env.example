# HVAC MCP environment variables
# Copy to .env for local dev. Never commit the real .env.

# Premium tier license key. Leave blank for free-tier-only operation.
# Dev-mode accepts "DEV-LOCAL-KEY-DO-NOT-SHIP" without hitting Stripe.
HVAC_MCP_LICENSE_KEY=

# Stripe webhook signing secret. Required when running --http and
# receiving events from Stripe. Get it from Dashboard → Developers →
# Webhooks → <your endpoint> → "Signing secret". Starts with whsec_...
STRIPE_WEBHOOK_SECRET=

# Optional: Stripe secret key (only needed if you later add code that
# READS from Stripe, e.g. customer lookups. Webhook verification uses
# STRIPE_WEBHOOK_SECRET, not this key.) Prefer a restricted key (rk_*).
STRIPE_SECRET=

# Directory for the SQLite license store. Default: ~/.hvac-mcp
# In containers, mount a volume and set this to its path.
HVAC_MCP_DATA_DIR=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# HTTP bind host (default 0.0.0.0) and port (default 8000)
# Railway/Fly inject $PORT automatically — no action needed on those platforms.
HVAC_MCP_HOST=0.0.0.0
PORT=8000
